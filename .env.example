# API
HTTP_ADDR=:8080
APP_ENV=local
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# MongoDB
MONGODB_URI=mongodb://launchpad:launchpad@localhost:27017/launchpad?authSource=admin
MONGODB_DATABASE=launchpad

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (required; change in every non-local environment)
JWT_SECRET=local-dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
PASSWORD_MIN_LENGTH=10

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_ORG_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
